# Copy this file to .env and fill in real values. .env is gitignored.

# --- Django core ---
DJANGO_SECRET_KEY=change-me-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
# Set to /researchdoc behind the UQCloud Nginx prefix; leave empty for runserver.
FORCE_SCRIPT_NAME=

# --- Database ---
# Leave MYSQL_PASSWORD empty to use SQLite locally (zero setup).
# Set it (and optionally the DB_* vars) to use MySQL like the deployment.
MYSQL_PASSWORD=
DB_NAME=researchdoc_db
DB_USER=root
DB_HOST=localhost
DB_PORT=3306

# --- AI (optional) ---
# Without a key the AI features fall back to deterministic offline output.
OPENAI_API_KEY=
LLM_MODEL=gpt-4o-mini

# --- Email (production only) ---
EMAIL_HOST=localhost
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=
DEFAULT_FROM_EMAIL=ResearchDoc <noreply@researchdoc.test>
